{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${ZCODE_PLUGIN_ROOT}/hooks/zmem-launch.js\" session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${ZCODE_PLUGIN_ROOT}/hooks/zmem-launch.js\" recall",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${ZCODE_PLUGIN_ROOT}/hooks/zmem-launch.js\" capture-failure",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${ZCODE_PLUGIN_ROOT}/hooks/zmem-launch.js\" reflect",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
